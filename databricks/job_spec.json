{
  "name": "fertilizer-weekly-refresh",
  "max_concurrent_runs": 1,
  "timeout_seconds": 3600,
  "schedule": {
    "quartz_cron_expression": "0 0 3 ? * SUN",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  },
  "git_source": {
    "git_url": "https://github.com/H1nokam1Kagura/fertilizer_market",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "tasks": [
    {
      "task_key": "refresh_and_load",
      "spark_python_task": {
        "python_file": "databricks/weekly_refresh.py",
        "source": "GIT"
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 0,
        "spark_conf": {
          "spark.master": "local[*]",
          "spark.databricks.cluster.profile": "singleNode"
        },
        "custom_tags": {
          "ResourceClass": "SingleNode"
        },
        "init_scripts": [
          {
            "volumes": {
              "destination": "/Volumes/ggo_agdev/bioinputs/_staging/init_pwsh.sh"
            }
          }
        ]
      },
      "max_retries": 1,
      "retry_on_timeout": false
    }
  ]
}
